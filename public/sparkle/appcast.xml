<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle" xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>Lagoon Studio Updates</title>
    <link>https://lagoon.video/sparkle/appcast.xml</link>
    <description>Most recent updates to Lagoon Studio</description>
    <language>en</language>

    <!--
      To add a new release, copy the <item> block below and fill in:
        - sparkle:version        Build number (e.g. 12)
        - sparkle:shortVersionString  Marketing version (e.g. 1.0.1)
        - title                  Release title shown to users
        - pubDate                RFC 2822 date: date -R
        - description            HTML release notes (inside CDATA)
        - enclosure url          GitHub Releases download URL for the DMG
        - enclosure sparkle:edSignature  Output of: sign_update Lagoon-Studio-{VERSION}.dmg
        - enclosure length       File size in bytes: stat -f%z Lagoon-Studio-{VERSION}.dmg
        - enclosure type         Always application/octet-stream for DMG
    -->

  </channel>
</rss>
